-- Safe Call Wrapper
local function SafeCall(func, ...)
    local ok, res = pcall(func, ...)
    if not ok then warn("Error: " .. tostring(res)) end
    return ok, res
end

-- Notification
local function Notify(Title, Content, Duration)
