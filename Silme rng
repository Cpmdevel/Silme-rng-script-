-- TELEPORTATION SYSTEM
local function teleportToZone(zoneName)
    local teleportButton = Services.CoreGui:FindFirstChild("TeleportButton")
    if teleportButton then
        local frame = teleportButton.Parent
        if frame then
            local zoneFrame = frame:FindFirstChild(zoneName)
            if zoneFrame and zoneFrame:FindFirstChild("Button") then
                local button = zoneFrame.Button
                if button then
                    local clickable = button:FindFirstChild("UICorner")
                    if clickable then
                        local fireClick = {
                            [1] = button.AbsolutePosition.X + button.AbsoluteSize.X / 2,
                            [2] = button.AbsolutePosition.Y + button.AbsoluteSize.Y / 2
                        }
                        VirtualUser:ClickButton(button, 0, fireClick[1], fireClick[2])
                        ShadowHub.Notify("Teleport", "Teleported to " .. zoneName, 2)
                        return true
                    end
                end
            end
        end
    end
    return false
end

