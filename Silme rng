local function AddToggle(tab, flag, label, func, interval)
    Rayfield:CreateToggle({
        Name = label,
        CurrentValue = false,
        Flag = flag,
        Callback = function(val)
            Toggles[flag] = val
            if val then
                if func then StartLoop(flag, func, interval or 0.5) end
            else
                StopLoop(flag)
            end
        end,
        Parent = tab
    })
end

