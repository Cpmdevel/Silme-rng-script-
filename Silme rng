-- ================================
-- UNIVERSAL BUTTON CLICKER
-- ================================
local function ClickButton(button)
    if not button or not (button:IsA("TextButton") or button:IsA("ImageButton")) then return false end
    local success = false
    
    -- Method 1: Click()
    pcall(function() button:Click(); success = true end)
    
    -- Method 2: Fire MouseButton1Click
    if not success then
        pcall(function()
            if button.MouseButton1Click then
                button.MouseButton1Click:Fire()
                success = true
            end
        end)
    end
    
    -- Method 3: VirtualInput simulation
    if not success then
        pcall(function()
            local pos = button.AbsolutePosition
            local size = button.AbsoluteSize
            if pos.X > 0 and pos.Y > 0 then
                local x, y = pos.X + size.X/2, pos.Y + size.Y/2
                VirtualInput:SendMouseButtonEvent(x, y, 0, true, game, 0)
                task.wait(0.05)
                VirtualInput:SendMouseButtonEvent(x, y, 0, false, game, 0)
                success = true
            end
        end)
    end
    
    -- Method 4: Mouse simulation (legacy)
    if not success then
        pcall(function()
            local m = LocalPlayer:GetMouse()
            local oldX, oldY = m.X, m.Y
            local pos = button.AbsolutePosition
            local size = button.AbsoluteSize
            m.X = pos.X + size.X/2
            m.Y = pos.Y + size.Y/2
            m:Click()
            m.X, m.Y = oldX, oldY
            success = true
        end)
    end
    
    return success
end

-- Find button by pattern (name, text, tooltip)
local function FindButton(pattern)
    local sources = {game:GetService("CoreGui"), LocalPlayer:FindFirstChild("PlayerGui")}
    pattern = pattern:lower()
    for _, source in ipairs(sources) do
        if source then
            for _, v in ipairs(source:GetDescendants()) do
                if v:IsA("TextButton") or v:IsA("ImageButton") then
                    local name = (v.Name or ""):lower()
                    local text = (v.Text or ""):lower()
                    local tooltip = (v.ToolTip or ""):lower()
                    if name:find(pattern) or text:find(pattern) or tooltip:find(pattern) then
                        return v
                    end
                end
            end
        end
    end
    return nil
end

