-- LOOP HANDLING
local function startLoop(name, callback, interval)
    if ShadowHub.Loops[name] then
        task.cancel(ShadowHub.Loops[name])
    end
    ShadowHub.Loops[name] = task.spawn(function()
        while ShadowHub.Toggles[name] do
            pcall(callback)
            task.wait(interval)
        end
    end)
end

local function stopLoop(name)
    if ShadowHub.Loops[name] then
        task.cancel(ShadowHub.Loops[name])
        ShadowHub.Loops[name] = nil
    end
end

-- TOGGLE HANDLING
local function setupToggle(tab, name, label, callback)
    local toggle = Rayfield:CreateToggle({
        Name = label,
        CurrentValue = false,
        Flag = name,
        Callback = function(value)
            ShadowHub.Toggles[name] = value
            if value then
                startLoop(name, callback, 0.5)
            else
                stopLoop(name)
            end
        end,
        Parent = tab
    })
    return toggle
end

