    local bodyGyro = Instance.new("BodyGyro")
    
    task.spawn(function()
        while ShadowHub.Toggles.Fly do
            if not flying and LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart") then
                flying = true
                local hrp = LocalPlayer.Character.HumanoidRootPart
                bodyVelocity.MaxForce = Vector3.new(1e6, 1e6, 1e6)
                bodyVelocity.Velocity = Vector3.new(0, 0, 0)
                bodyGyro.MaxTorque = Vector3.new(1e6, 1e6, 1e6)
                bodyGyro.CFrame = hrp.CFrame
                bodyVelocity.Parent = hrp
                bodyGyro.Parent = hrp
                LocalPlayer.Character.Humanoid.PlatformStand = true
            elseif LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart") then
                local hrp = LocalPlayer.Character.HumanoidRootPart
                local camPos = workspace.CurrentCamera.CFrame.Position
                local direction = (camPos - hrp.Position).Unit
                bodyVelocity.Velocity = direction * 50
                bodyGyro.CFrame = CFrame.new(hrp.Position, camPos)
            end
            task.wait()
        end
        if bodyVelocity.Parent then
            bodyVelocity:Destroy()
            bodyGyro:Destroy()
            if LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("Humanoid") then
                LocalPlayer.Character.Humanoid.PlatformStand = false
            end
        end
        flying = false
    end)
end)

