local ExecutorName = "Unknown"
local function DetectExecutor()
    local executors = {
        {name = "Delta", check = function() return identifyexecutor and identifyexecutor():find("Delta") end},
        {name = "Hydrogen", check = function() return identifyexecutor and identifyexecutor():find("Hydrogen") end},
        {name = "Fluxus", check = function() return identifyexecutor and identifyexecutor():find("Fluxus") end},
        {name = "Arceus X", check = function() return identifyexecutor and identifyexecutor():find("Arceus") end},
        {name = "Codex", check = function() return identifyexecutor and identifyexecutor():find("Codex") end},
        {name = "Vega X", check = function() return identifyexecutor and identifyexecutor():find("Vega") end},
        {name = "Electron", check = function() return identifyexecutor and identifyexecutor():find("Electron") end},
        {name = "KRNL", check = function() return isfolder and isfolder("krnl") end},
        {name = "Synapse X", check = function() return syn and syn.crypt end},
        {name = "ScriptWare", check = function() return script_context and script_context.executor == "ScriptWare" end}
    }
    for _, exec in ipairs(executors) do
        if exec.check() then return exec.name end
    end
    return "Unknown"
end
