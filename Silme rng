local function checkForRareRoll()
    local rollResult = Services.CoreGui:FindFirstChild("RollResult")
    if rollResult and rollResult:FindFirstChild("SlimeName") then
        local slimeName = rollResult.SlimeName.Text or ""
        for rarity, _ in pairs(SlimeRarities) do
            if slimeName:find(rarity) then
                ShadowHub.Stats.RareRolls = ShadowHub.Stats.RareRolls + 1
                ShadowHub.Notify("RARE ROLL!", "You rolled a " .. slimeName, 4)
                break
            end
        end
    end
