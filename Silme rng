-- Universal Button Clicker (works on all executors)
local function ClickButton(button)
    if not button or not button:IsA("GuiButton") then return false end
    local clicked = false
    -- Method 1: Click()
    pcall(function() button:Click(); clicked = true end)
    -- Method 2: Fire MouseButton1Click
    if not clicked then
        pcall(function() if button.MouseButton1Click then button.MouseButton1Click:Fire(); clicked = true end end)
    end
    -- Method 3: Simulate mouse click via VirtualInput
    if not clicked then
        pcall(function()
            local pos = button.AbsolutePosition
            local size = button.AbsoluteSize
            if pos.X > 0 and pos.Y > 0 then
                local x, y = pos.X + size.X/2, pos.Y + size.Y/2
                VirtualInput:SendMouseButtonEvent(x, y, 0, true, game, 0)
                task.wait(0.05)
                VirtualInput:SendMouseButtonEvent(x, y, 0, false, game, 0)
                clicked = true
            end
        end)
    end
    -- Method 4: Fire click using mousescript
    if not clicked then
        pcall(function()
            local m = game:GetService("Players").LocalPlayer:GetMouse()
            local oldPos = m.X
            m.X = button.AbsolutePosition.X + button.AbsoluteSize.X/2
            m.Y = button.AbsolutePosition.Y + button.AbsoluteSize.Y/2
            m:Click()
            m.X = oldPos
            clicked = true
        end)
    end
    return clicked
end

-- Find Game Button by name pattern (case insensitive)
local function FindButton(pattern)
    local sources = {game:GetService("CoreGui"), LocalPlayer:FindFirstChild("PlayerGui")}
    for _, source in pairs(sources) do
        if source then
            for _, v in pairs(source:GetDescendants()) do
                if v:IsA("TextButton") or v:IsA("ImageButton") then
                    if v.Name and v.Name:lower():find(pattern:lower()) then
                        return v
                    end
                    if v.Text and v.Text:lower():find(pattern:lower()) then
                        return v
                    end
                    if v.ToolTip and v.ToolTip:lower():find(pattern:lower()) then
                        return v
                    end
                end
            end
        end
    end
    return nil
end

-- Core Functions
local function DoRoll()
    local btn = FindButton("roll") or FindButton("spin") or FindButton("click")
    if btn then
        if ClickButton(btn) then
