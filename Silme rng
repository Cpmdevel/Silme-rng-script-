-- ================================
-- SAFE CALL WRAPPER
-- ================================
local function SafeCall(func, ...)
    local ok, res = pcall(func, ...)
    if not ok then
        warn("[Shadow Hub] Error: " .. tostring(res))
    end
    return ok, res
end

