-- Enhanced AutoUpgrade with full menu support
local function AutoUpgrade()
    SafeCall(function()
        local upgradeBtn = FindButton("upgrade") or FindButton("buy") or FindButton("level") or FindButton("unlock") or FindButton("menu")
        if not upgradeBtn then return end
        
        if not ClickButton(upgradeBtn) then return end
        task.wait(0.6)
        
        -- Get all upgrade buttons
        local playerGui = LocalPlayer:FindFirstChild("PlayerGui")
        if not playerGui then return end
        
        local upgradeOptions = {}
        local priorityMap = {
            ["luck"] = 1,
            ["critical"] = 2,
            ["crit"] = 2,
            ["damage"] = 3,
            ["speed"] = 4,
            ["attack"] = 5,
            ["defense"] = 6
        }
        
        -- Collect all visible upgrade buttons
        for _, btn in ipairs(playerGui:GetDescendants()) do
            if (btn:IsA("TextButton") or btn:IsA("ImageButton")) and btn.Visible then
                local txt = tostring(btn.Text or ""):lower()
                local btnName = tostring(btn.Name or ""):lower()
                
                -- Check for upgrade keywords
                for keyword, priority in pairs(priorityMap) do
                    if txt:find(keyword, 1, true) or btnName:find(keyword, 1, true) then
                        table.insert(upgradeOptions, {button = btn, priority = priority, keyword = keyword})
                        break
                    end
                end
            end
        end
        
        -- Sort by priority and click highest priority
        if #upgradeOptions > 0 then
            table.sort(upgradeOptions, function(a, b) return a.priority < b.priority end)
            local targetBtn = upgradeOptions[1].button
            if ClickButton(targetBtn) then
                Stats.Upgrades = Stats.Upgrades + 1
                task.wait(0.3)
            end
        end
    end)
end

