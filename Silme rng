    if isfile("ShadowHub_SlimeRNG_Config.json") then
        local configString = readfile("ShadowHub_SlimeRNG_Config.json")
        local loaded = Services.Http:JSONDecode(configString)
        for k, v in pairs(loaded) do
            if ShadowHub.Flags[k] then
                Rayfield:SetFlag(k, v)
                ShadowHub.Toggles[k] = v
            end
        end
        ShadowHub.Notify("Config Loaded", "Configuration has been loaded successfully.", 3)
    else
        ShadowHub.Notify("No Config Found", "No saved configuration found.", 3)
    end
end

-- REJOIN SERVER
local function rejoinServer()
    local teleport = game:GetService("TeleportService")
    local placeId = game.PlaceId
    teleport:Teleport(placeId)
end

-- SERVER HOP
local function serverHop()
    local servers = {}
    for _, v in pairs(game:GetService("HttpService"):JSONDecode(game:HttpGetAsync("https://games.roblox.com/v1/games/" .. game.PlaceId .. "/servers/Public?limit=100"))) do
        if type(v) == "table" and v.playing < v.maxPlayers then
            table.insert(servers, v.id)
        end
    end
    if #servers > 0 then
        game:GetService("TeleportService"):TeleportToPlaceInstance(game.PlaceId, servers[math.random(1, #servers)], LocalPlayer)
    else
        ShadowHub.Notify("Server Hop", "No available servers found.", 3)
    end
end

