-- ================================
-- UNIVERSAL BUTTON CLICKER - ENHANCED
-- ================================
local function ClickButton(button)
    if not button or not (button:IsA("TextButton") or button:IsA("ImageButton")) then
        return false
    end
    
    local clicked = false
    
    -- Method 1: Direct :Click()
    SafeCall(function() 
        button:Click()
        clicked = true 
    end)
    
    -- Method 2: Fire MouseButton1Click
    if not clicked then
        SafeCall(function()
            if button.MouseButton1Click then
                button.MouseButton1Click:Fire()
                clicked = true
            end
        end)
    end
    
    -- Method 3: Activate
    if not clicked then
        SafeCall(function()
            button:Activate()
            clicked = true
        end)
    end
    
    -- Method 4: VirtualInput simulation
    if not clicked then
        SafeCall(function()
            local pos = button.AbsolutePosition
            local size = button.AbsoluteSize
            if pos.X > 0 and pos.Y > 0 and size.X > 0 and size.Y > 0 then
                local x = pos.X + size.X / 2
                local y = pos.Y + size.Y / 2
                VirtualInput:SendMouseButtonEvent(x, y, 0, true, game, 0)
                task.wait(0.05)
                VirtualInput:SendMouseButtonEvent(x, y, 0, false, game, 0)
                clicked = true
            end
        end)
    end
    
    -- Method 5: Mouse simulation (legacy)
    if not clicked then
        SafeCall(function()
            local mouse = LocalPlayer:GetMouse()
            local oldX, oldY = mouse.X, mouse.Y
            local pos = button.AbsolutePosition
            local size = button.AbsoluteSize
            if pos.X > 0 and pos.Y > 0 then
                mouse.X = pos.X + size.X / 2
                mouse.Y = pos.Y + size.Y / 2
                task.wait(0.05)
                mouse:Click()
                task.wait(0.05)
                mouse.X, mouse.Y = oldX, oldY
                clicked = true
            end
        end)
    end
    
    return clicked
end

-- Find button by pattern
local function FindButton(pattern)
    if not pattern then return nil end
    pattern = tostring(pattern):lower()
    local sources = {game:GetService("CoreGui"), LocalPlayer:FindFirstChild("PlayerGui")}
    
    for _, source in ipairs(sources) do
        if source then
            for _, v in ipairs(source:GetDescendants()) do
                if v:IsA("TextButton") or v:IsA("ImageButton") then
                    local name = tostring(v.Name or ""):lower()
                    local text = tostring(v.Text or ""):lower()
                    local tooltip = tostring(v.ToolTip or ""):lower()
                    if name:find(pattern, 1, true) or text:find(pattern, 1, true) or tooltip:find(pattern, 1, true) then
                        return v
                    end
                end
            end
        end
    end
    return nil
end

-- Find all buttons matching pattern
local function FindAllButtons(pattern)
    if not pattern then return {} end
    pattern = tostring(pattern):lower()
    local results = {}
    local sources = {game:GetService("CoreGui"), LocalPlayer:FindFirstChild("PlayerGui")}
    
    for _, source in ipairs(sources) do
        if source then
            for _, v in ipairs(source:GetDescendants()) do
                if v:IsA("TextButton") or v:IsA("ImageButton") then
                    local name = tostring(v.Name or ""):lower()
                    local text = tostring(v.Text or ""):lower()
                    local tooltip = tostring(v.ToolTip or ""):lower()
                    if name:find(pattern, 1, true) or text:find(pattern, 1, true) or tooltip:find(pattern, 1, true) then
                        table.insert(results, v)
                    end
                end
            end
        end
    end
    return results
end

