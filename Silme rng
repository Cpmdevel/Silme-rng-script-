-- ================================
-- LOOP MANAGER
-- ================================
local function StartLoop(name, func, interval)
    if Loops[name] then task.cancel(Loops[name]) end
    Loops[name] = task.spawn(function()
        while Toggles[name] and HubActive do
            SafeCall(func)
            task.wait(interval)
        end
    end)
end

local function StopLoop(name)
    if Loops[name] then 
        task.cancel(Loops[name])
        Loops[name] = nil 
    end
end

